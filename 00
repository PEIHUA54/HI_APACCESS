// 系統申請(新增/修改)
[HttpPost]
public JsonResult ApplySystem([Bind] M_SYS_Apply model)
{
    try
    {
        if (!ModelState.IsValid)
        {
            return Json(new { success = false, message = "資料驗證失敗" });
        }

        string empNo = this.Emp_NO;
        string empName = F_SYS.GetEmployeeName(empNo);

        if (string.IsNullOrEmpty(empName))
        {
            return Json(new { success = false, message = "無法取得員工姓名" });
        }

        // 檢查是否全部都已存在
        bool systemExists = F_SYS.CheckSystemExistsInApSys(model.SYS_ID);
        bool group001Exists = F_SYS.CheckSystemHasGroup001(model.SYS_ID);
        bool userExists = F_SYS.CheckUserInGroup001(model.SYS_ID, empNo);

        // 只有在「新增」，才檢查是否重複申請
        if (model.Action == "Add" && systemExists && group001Exists && userExists)
        {
            return Json(new
            {
                success = false,
                message = "此系統已完成申請，您已具有管理權限。 \r\n如需修改系統資訊，請點擊修改按鈕。"
            });
        }

        // 執行系統申請流程
        string result = ProcessSystemApply(model, empNo, empName);

        if (result == null || !result.Contains("fail"))
        {
            string successMessage = model.Action == "Add" ? "系統申請成功" : "系統修改成功";
            return Json(new { success = true, message = successMessage });
        }
        else
        {
            string failMessage = model.Action == "Add" ? "系統申請失敗：" : "系統修改失敗：";
            return Json(new { success = false, message = failMessage + result });
        }
    }
    catch (Exception ex)
    {
        return Json(new { success = false, message = "系統處理發生錯誤：" + ex.Message });
    }
}

// 系統申請處理流程
private string ProcessSystemApply(M_SYS_Apply model, string empNo, string empName)
{
    string result = null;

    // 1: 檢查系統是否存在於 AP_SYS
    bool systemExists = F_SYS.CheckSystemExistsInApSys(model.SYS_ID);

    if (!systemExists)
    {
        // 系統不存在 -> 新增系統（包含新欄位）
        result = F_SYS.InsertSystemToApSys(model, empNo);
        if (result != null && result.Contains("fail")) return result;
    }
    else
    {
        // 系統存在 -> 更新系統（包含新欄位）
        result = F_SYS.UpdateSystem(model, empNo);
        if (result != null && result.Contains("fail")) return result;
    }

    // 2: 檢查是否有 001 群組
    bool group001Exists = F_SYS.CheckSystemHasGroup001(model.SYS_ID);
    if (!group001Exists)
    {
        // 001 群組不存在 -> 新增 001 群組
        result = F_SYS.InsertGroup001(model.SYS_ID, empNo);
        if (result != null && result.Contains("fail")) return result;
    }

    // 3: 檢查使用者是否已在 001 群組
    bool userExists = F_SYS.CheckUserInGroup001(model.SYS_ID, empNo);
    if (!userExists)
    {
        // 使用者不存在 -> 新增使用者到 001 群組
        result = F_SYS.InsertUserToGroup001(model.SYS_ID, empNo, empName);
        if (result != null && result.Contains("fail")) return result;
    }

    return result;
}

