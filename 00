DECLARE @SYS_ID VARCHAR(100) = 'HI_APACCESS'
DECLARE @CONTROLLER_NAME VARCHAR(100) = 'Account'

-- 確認最新的 ACTION_TIME 是什麼時候
SELECT 
    MAX([ACTION_TIME]) AS 最新時間,
    MIN([ACTION_TIME]) AS 最舊時間,
    COUNT(*)           AS 總筆數
FROM [HI-APLOG].[dbo].[AP_EVENT_LOG]
WHERE [SYS_ID] = @SYS_ID
  AND [CONTROLLER_NAME] = @CONTROLLER_NAME
