// 取得所有系統
case QueryKey.GetAllSystemsForBatch:
    return @"
        SELECT [SYS_ID], [SYS_NAME],
               [NOTIFY_AUTOS_IT], [NOTIFY_AUTOS_USERS],
               [AUTOS_CONTROLLER_NAME]
        FROM [HI-APLOG].[dbo].[AP_SYS]
        ORDER BY [SYS_ID]
    ";

// 帳號清單（全欄位）
case QueryKey.GetUserListForMail:
    return @"
        SELECT
            u.[U_ID],
            u.[U_NAME],
            u.[APG_NO],
            g.[APG_NAME],
            m.[ORGAN_NO],
            m.[ORGAN_CAP],
            u.[CREATOR],
            CONVERT(varchar, u.[CREATE_TIME], 120) AS CREATE_TIME,
            u.[EDITOR],
            CONVERT(varchar, u.[EDIT_TIME], 120) AS EDIT_TIME
        FROM [HI-AUTOS].[dbo].[AP_USER] u
        LEFT JOIN [HI-AUTOS].[dbo].[AP_GROUP] g
            ON u.[SYS_ID] = g.[SYS_ID] AND u.[APG_NO] = g.[APG_NO]
        LEFT JOIN [HI-AUTOS].[dbo].[M1EMP_MAST] m
            ON u.[U_ID] = m.[EMP_NO]
        WHERE u.[SYS_ID] = @SYS_ID
        ORDER BY u.[APG_NO], u.[U_ID]
    ";

// 登入次數（最近半年）
case QueryKey.GetLoginCountList:
    return @"
        DECLARE @CONTROLLER_NAME VARCHAR(100)
        SELECT @CONTROLLER_NAME = [AUTOS_CONTROLLER_NAME]
        FROM [HI-APLOG].[dbo].[AP_SYS]
        WHERE [SYS_ID] = @SYS_ID

        SELECT
            A.[U_ID],
            A.[U_NAME],
            COUNT(B.[LOG_ID]) AS LOGIN_COUNT
        FROM [HI-AUTOS].[dbo].[AP_USER] AS A
        LEFT JOIN [HI-AUTOS].[dbo].[M1EMP_MAST] AS NT
            ON A.[U_ID] = NT.[EMP_NO]
        LEFT JOIN [HI-APLOG].[dbo].[AP_EVENT_LOG] AS B
            ON A.[SYS_ID] = B.[SYS_ID]
            AND NT.[EMP_DOM_ID] = B.[ACTION_USER]
            AND B.[CONTROLLER_NAME] = @CONTROLLER_NAME
            AND B.[LOG_TIME] >= DATEADD(MONTH, -6, GETDATE())
        WHERE A.[SYS_ID] = @SYS_ID
        GROUP BY A.[U_ID], A.[U_NAME]
        ORDER BY A.[U_ID]
    ";

// 員工信箱
case QueryKey.GetEmpEmail:
    return @"
        SELECT [EMP_EMAIL]
        FROM [HI-AUTOS].[dbo].[EMPLOYEE_MAIL]
        WHERE [EMP_ID] = @EMP_NO
    ";


