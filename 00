                <thead style="position: sticky; top: -0.1px; z-index: 2;">
                    <tr>
                        <th style="width:100px;">
                            <button type="button" class="btn btn-green" id="btnAdd">新增</button>
                        </th>
                        <th style="width:150px;">@Html.DisplayNameFor(x => x.SYS_ID)</th>
                        <th style="width:200px;">@Html.DisplayNameFor(x => x.SYS_NAME)</th>
                        <th style="width:200px;">@Html.DisplayNameFor(x => x.NOTIFY_AUTOS_IT)</th>
                        <th style="width:200px;">@Html.DisplayNameFor(x => x.NOTIFY_AUTOS_USERS)</th>
                        <th style="width:200px;">@Html.DisplayNameFor(x => x.AUTOS_CONTROLLER_NAME)</th>
                        <th style="width:100px;">@Html.DisplayNameFor(x => x.CREATOR)</th>
                        <th style="width:150px;">@Html.DisplayNameFor(x => x.CREATE_TIME)</th>
                        <th style="width:100px;">@Html.DisplayNameFor(x => x.EDITOR)</th>
                        <th style="width:150px;">@Html.DisplayNameFor(x => x.EDIT_TIME)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <button type="button" class="btn btn-blue btn-edit"
                                            data-sysid="@item.SYS_ID"
                                            data-sysname="@item.SYS_NAME">修改</button>
                                </td>
                                <td>@item.SYS_ID</td>
                                <td>@item.SYS_NAME</td>
                                <td>@item.NOTIFY_AUTOS_IT</td>
                                <td>@item.NOTIFY_AUTOS_USERS</td>
                                <td>@item.AUTOS_CONTROLLER_NAME</td>
                                <td>@item.CREATOR</td>
                                <td>@item.CREATE_TIME</td>
                                <td>@item.EDITOR</td>
                                <td>@item.EDIT_TIME</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="10" style="text-align:center; font-weight:600;">查無資料</td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </div>
</div>

<!-- ── Modal ── -->
<div class="modal fade" id="systemModal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">新增系統</h5>
                <button type="button" class="close" data-dismiss="modal"><span>&times;</span></button>
            </div>
            <div class="modal-body">
                <form id="systemForm">

                    <!-- 系統ID -->
                    <div class="form-group">
                        <div class="field-label">系統ID <span class="text-danger">*</span></div>
                        <div class="field-control">
                            <input type="text" class="form-control" id="sysId" name="SYS_ID"
                                   required maxlength="100" autocomplete="off">
                        </div>
                    </div>

                    <!-- 系統名稱 -->
                    <div class="form-group">
                        <div class="field-label">系統名稱 <span class="text-danger">*</span></div>
                        <div class="field-control">
                            <input type="text" class="form-control" id="sysName" name="SYS_NAME"
                                   required maxlength="100" autocomplete="off">
                        </div>
                    </div>

                    <!-- 資訊人員 -->
                    <div class="form-group">
                        <div class="field-label">權限通知對象<br />資訊人員</div>
                        <div class="field-control">
                            <div class="emp-search-wrap">
                                <input type="text" class="form-control" id="searchIt"
                                       placeholder="輸入員工編號或姓名" autocomplete="off">
                                <button type="button" class="btn btn-blue"
                                        onclick="searchEmployee('It')">搜尋</button>
                            </div>
                            <div class="emp-result-box">
                                <div class="emp-result-header">
                                    <span>員工編號</span><span>員工名稱</span>
                                </div>
                                <select id="empResultIt" class="emp-result-select" multiple
                                        ondblclick="addSelected('It')"></select>
                            </div>
                            <div class="field-hint">雙擊或按「加入」將選取的人員加入清單</div>
                            <button type="button" class="btn btn-sm btn-green mt-1"
                                    onclick="addSelected('It')">＋ 加入已選</button>
                            <div id="selectedItList" class="selected-list" style="display:none;">
                                <strong>已選擇：</strong>
                                <div id="selectedItContent" class="selected-content"></div>
                            </div>
                        </div>
                    </div>

                    <!-- 一般USER -->
                    <div class="form-group">
                        <div class="field-label">權限通知對象<br />一般USER</div>
                        <div class="field-control">
                            <div class="emp-search-wrap">
                                <input type="text" class="form-control" id="searchUsers"
                                       placeholder="輸入員工編號或姓名" autocomplete="off">
                                <button type="button" class="btn btn-blue"
                                        onclick="searchEmployee('Users')">搜尋</button>
                            </div>
                            <div class="emp-result-box">
                                <div class="emp-result-header">
                                    <span>員工編號</span><span>員工名稱</span>
                                </div>
                                <select id="empResultUsers" class="emp-result-select" multiple
                                        ondblclick="addSelected('Users')"></select>
                            </div>
                            <div class="field-hint">雙擊或按「加入」將選取的人員加入清單</div>
                            <button type="button" class="btn btn-sm btn-green mt-1"
                                    onclick="addSelected('Users')">＋ 加入已選</button>
                            <div id="selectedUsersList" class="selected-list" style="display:none;">
                                <strong>已選擇：</strong>
                                <div id="selectedUsersContent" class="selected-content"></div>
                            </div>
                        </div>
                    </div>

                    <!-- Controller -->
                    <div class="form-group">
                        <div class="field-label">權限CONTROLLER<br />名稱</div>
                        <div class="field-control">
                            <select id="controllerName" class="ctrl-select" multiple>
                                <option value="" disabled>-- 請先輸入系統ID後按下方按鈕載入 --</option>
                            </select>
                            <div class="field-hint">Ctrl + 點擊可複選；新系統無可選項目（存null）</div>
                            <button type="button" class="btn btn-sm btn-blue mt-1"
                                    onclick="loadControllerList(null)">載入Controller清單</button>
                            <div id="selectedController" class="selected-list" style="display:none;">
                                <strong>已選擇：</strong>
                                <div id="selectedControllerContent" class="selected-content"></div>
                            </div>
                        </div>
                    </div>

                    <input type="hidden" id="actionType" name="Action" value="Add">
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-green" id="btnSave">儲存</button>
                <button type="button" class="btn btn-gray" data-dismiss="modal">取消</button>
            </div>
        </div>
    </div>
</div>

@section Scripts{
<script>
    // 已選資料（全域）
    var selectedIt    = [];
    var selectedUsers = [];

    $(document).ready(function () {
        initPage();
    });

    function initPage() {
        $('#btnAdd').off('click').on('click', function () {
            resetForm();
            $('#modalTitle').text('新增系統');
            $('#sysId').prop('readonly', false);
            $('#actionType').val('Add');
            $('#systemModal').modal('show');
        });

        $('.btn-edit').off('click').on('click', function () {
            editSystem($(this).data('sysid'), $(this).data('sysname'));
        });

        $('#btnSave').off('click').on('click', function () {
            saveSystem();
        });

        // Enter 觸發搜尋
        $('#searchIt').on('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); searchEmployee('It'); }
        });
        $('#searchUsers').on('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); searchEmployee('Users'); }
        });

        // Controller 選擇變動更新 tag
        $('#controllerName').on('change', function () {
            updateControllerDisplay();
        });
    }

    // ── 員工搜尋 ────────────────────────────────────────────────
    function searchEmployee(type) {
        var inputId = type === 'It' ? '#searchIt' : '#searchUsers';
        var keyword = $(inputId).val().trim().toUpperCase(); // 前端轉大寫

        var resultId = '#empResult' + type;
        $(resultId).empty().append('<option disabled>搜尋中…</option>');

        $.ajax({
            url:      '@Url.Action("GetEmployeeList", "SYS")',
            type:     'GET',
            data:     { keyword: keyword },
            dataType: 'json',
            success: function (response) {
                $(resultId).empty();
                if (response.success && response.data && response.data.length > 0) {
                    response.data.forEach(function (emp) {
                        var parts   = emp.text.split(' - ');
                        var empNo   = parts[0] || '';
                        var empName = parts[1] || '';
                        // option 顯示：編號用固定寬空白對齊名稱欄
                        var displayText = empNo + '        ' + empName;
                        $('<option>')
                            .val(empNo)
                            .text(displayText)
                            .data('empname', empName)
                            .appendTo($(resultId));
                    });
                } else {
                    $(resultId).append('<option disabled>查無符合員工</option>');
                }
            },
            error: function () {
                $(resultId).empty().append('<option disabled>搜尋失敗</option>');
            }
        });
    }

    // ── 加入已選 ────────────────────────────────────────────────
    function addSelected(type) {
        var resultId  = '#empResult' + type;
        var arr       = type === 'It' ? selectedIt : selectedUsers;

        $(resultId + ' option:selected').each(function () {
            var empNo   = $(this).val();
            var empName = $(this).data('empname') || '';
            if (!empNo) return;
            if (!arr.some(function (e) { return e.empNo === empNo; })) {
                arr.push({ empNo: empNo, empName: empName });
            }
        });

        renderSelectedTags(type);
    }

    // ── 移除已選 ────────────────────────────────────────────────
    function removeSelected(type, empNo) {
        if (type === 'It') {
            selectedIt    = selectedIt.filter(function (e) { return e.empNo !== empNo; });
        } else {
            selectedUsers = selectedUsers.filter(function (e) { return e.empNo !== empNo; });
        }
        renderSelectedTags(type);
    }

    // ── 渲染 tag ────────────────────────────────────────────────
    function renderSelectedTags(type) {
        var listId    = type === 'It' ? '#selectedItList'    : '#selectedUsersList';
        var contentId = type === 'It' ? '#selectedItContent' : '#selectedUsersContent';
        var arr       = type === 'It' ? selectedIt           : selectedUsers;

        if (arr.length > 0) {
            var html = arr.map(function (e) {
                var label = e.empName ? e.empNo + ' ' + e.empName : e.empNo;
                return '<span class="selected-tag">' + label +
                    ' <span class="tag-remove" onclick="removeSelected(\'' + type + '\',\'' + e.empNo + '\')">&times;</span>' +
                    '</span>';
            }).join('');
            $(contentId).html(html);
            $(listId).show();
        } else {
            $(listId).hide();
        }
    }

    // ── Controller 載入 ──────────────────────────────────────────
    function loadControllerList(preSelected) {
        var sysId = $('#sysId').val().trim();
        if (!sysId) { alert('請先輸入系統ID'); return; }

        preSelected = preSelected || [];

        $.get('@Url.Action("GetControllerList", "SYS")', { sysId: sysId }, function (response) {
            $('#controllerName').empty();

            if (response.success && response.data && response.data.length > 0) {
                response.data.forEach(function (ctrl) {
                    var isSelected = preSelected.indexOf(ctrl.CONTROLLER_NAME) >= 0;
                    $('#controllerName').append(
                        new Option(ctrl.CONTROLLER_NAME, ctrl.CONTROLLER_NAME, isSelected, isSelected)
                    );
                });
            } else {
                $('#controllerName').append(
                    '<option value="" disabled>-- 此系統無Controller（新系統或尚未設定）--</option>'
                );
            }
            updateControllerDisplay();
        });
    }

    // ── Controller tag 顯示 ──────────────────────────────────────
    function updateControllerDisplay() {
        var selected = $('#controllerName').val();
        if (selected && selected.length > 0) {
            var html = selected.map(function (v) {
                return '<span class="selected-tag">' + v + '</span>';
            }).join('');
            $('#selectedControllerContent').html(html);
            $('#selectedController').show();
        } else {
            $('#selectedController').hide();
        }
    }

    // ── 儲存 ────────────────────────────────────────────────────
    function saveSystem() {
        var sysId   = $('#sysId').val().trim().toUpperCase();
        var sysName = $('#sysName').val().trim();

        if (!sysId || !sysName) { alert('系統ID和系統名稱為必填'); return; }

        // 員工編號以 ; 分隔（已為大寫）
        var notifyIt    = selectedIt.map(function (e)    { return e.empNo; }).join(';');
        var notifyUsers = selectedUsers.map(function (e) { return e.empNo; }).join(';');

        // Controller 多選以 ; 分隔
        var ctrlVal = $('#controllerName').val();
        var ctrlStr = (ctrlVal && ctrlVal.length > 0) ? ctrlVal.join(';') : '';

        var formData = {
            SYS_ID:                sysId,
            SYS_NAME:              sysName,
            NOTIFY_AUTOS_IT:       notifyIt,
            NOTIFY_AUTOS_USERS:    notifyUsers,
            AUTOS_CONTROLLER_NAME: ctrlStr,
            Action:                $('#actionType').val()
        };

        $.ajax({
            url:      '@Url.Action("ApplySystem", "SYS")',
            type:     'POST',
            data:     formData,
            dataType: 'json',
            success: function (response) {
                if (response.success) {
                    alert(response.message);
                    $('#systemModal').modal('hide');
                    location.reload();
                } else {
                    alert(response.message);
                }
            },
            error: function () { alert('儲存時發生錯誤'); }
        });
    }

    // ── 編輯 ────────────────────────────────────────────────────
    function editSystem(sysId, sysName) {
        resetForm();
        $('#modalTitle').text('修改系統');
        $('#sysId').val(sysId).prop('readonly', true);
        $('#sysName').val(sysName);
        $('#actionType').val('Edit');

        $.get('@Url.Action("GetSystemDetail", "SYS")', { sysId: sysId }, function (response) {
            if (!response.success) return;
            var system = response.data;

            // 補回員工姓名的共用函數
            function loadEmpTags(empNosStr, type) {
                if (!empNosStr) return;
                $.get('@Url.Action("GetEmployeesByNos", "SYS")', { empNos: empNosStr }, function (res) {
                    var arr = type === 'It' ? selectedIt : selectedUsers;

                    if (res.success && res.data && res.data.length > 0) {
                        res.data.forEach(function (emp) {
                            var empNo   = emp.id;
                            var empName = emp.text.split(' - ')[1] || '';
                            if (!arr.some(function (e) { return e.empNo === empNo; })) {
                                arr.push({ empNo: empNo, empName: empName });
                            }
                        });
                    } else {
                        // fallback：只顯示編號
                        empNosStr.split(';').forEach(function (no) {
                            no = no.trim();
                            if (no && !arr.some(function (e) { return e.empNo === no; })) {
                                arr.push({ empNo: no, empName: '' });
                            }
                        });
                    }
                    renderSelectedTags(type);
                });
            }

            loadEmpTags(system.NOTIFY_AUTOS_IT,    'It');
            loadEmpTags(system.NOTIFY_AUTOS_USERS,  'Users');

            // Controller 帶入已選值
            var preSelected = system.AUTOS_CONTROLLER_NAME
                ? system.AUTOS_CONTROLLER_NAME.split(';').map(function (s) { return s.trim(); })
                : [];
            loadControllerList(preSelected);
        });

        $('#systemModal').modal('show');
    }

    // ── 重置 ────────────────────────────────────────────────────
    function resetForm() {
        $('#systemForm')[0].reset();
        $('#sysId').prop('readonly', false);
        selectedIt    = [];
        selectedUsers = [];
        $('#selectedItList, #selectedUsersList, #selectedController').hide();
        $('#empResultIt, #empResultUsers').empty();
        $('#controllerName').empty().append(
            '<option value="" disabled>-- 請先輸入系統ID後按下方按鈕載入 --</option>'
        );
    }
</script>
}


