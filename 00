[系統申請管理] 新增/修改
這資料表[HI-APLOG].[dbo].[AP_SYS]新增3個欄位
NOTIFY_AUTOS_IT  varchar(500)   Checked  權限通知對象_資訊人員
NOTIFY_AUTOS_USERS   varchar(500)   Checked  權限通知對象_一般USER
AUTOS_CONTROLLER_NAME varchar(100)   Checked  權限CONTROLLER名稱 –從HI-APLOG].[dbo].[AP_SYS_CTRL]
然後在申請系統的新增modal跟修改modal 增加這三個欄位的選項
1.NOTIFY_AUTOS_IT 從[HI-AUTOS].[dbo].[M1EMP_MAST]取員工姓名[EMP_NAME]跟員工編號[EMP_NO]
下拉選項(選項畫面如圖)選完立即呈現在 modal上選了誰
2.NOTIFY_AUTOS_USERS 從[HI-AUTOS].[dbo].[M1EMP_MAST]取員工姓名[EMP_NAME]跟員工編號[EMP_NO]
下拉選項(選項畫面如圖)選完立即呈現在 modal上選了誰
3.AUTOS_CONTROLLER_NAME 從HI-APLOG].[dbo].[AP_SYS_CTRL]根據[SYS_ID]取[CONTROLLER_NAME]
下拉選項(選項畫面如圖) 選完立即呈現在 modal上選了哪個controller

//-- controller
    #region 申請系統
    // 申請系統介面
    public ActionResult SYS_APPLY()
    {
        var systems = F_SYS.GetAvailableSystems(this.Emp_NO);  // 取系統清單
        return View(systems);
    }

    // 系統申請(新增/修改)
    [HttpPost]
    public JsonResult ApplySystem([Bind] M_SYS_Apply model)
    {
        try
        {
            if (!ModelState.IsValid)
            {
                return Json(new { success = false, message = "資料驗證失敗" });
            }

            string empNo = this.Emp_NO;
            string empName = F_SYS.GetEmployeeName(empNo);

            if (string.IsNullOrEmpty(empName))
            {
                return Json(new { success = false, message = "無法取得員工姓名" });
            }

            // 檢查是否全部都已存在
            bool systemExists = F_SYS.CheckSystemExistsInApSys(model.SYS_ID);
            bool group001Exists = F_SYS.CheckSystemHasGroup001(model.SYS_ID);
            bool userExists = F_SYS.CheckUserInGroup001(model.SYS_ID, empNo);

            // 只有在「新增」，才檢查是否重複申請
            if (model.Action == "Add" && systemExists && group001Exists && userExists)
            {
                return Json(new
                {
                    success = false,
                    message = "此系統已完成申請，您已具有管理權限。 \r\n如需修改系統名稱，請點擊修改按鈕。"
                });
            }

            // 執行系統申請流程
            string result = ProcessSystemApply(model.SYS_ID, model.SYS_NAME, empNo, empName);

            if (result == null || !result.Contains("fail"))
            {
                string successMessage = model.Action == "Add" ? "系統申請成功" : "系統修改成功";
                return Json(new { success = true, message = successMessage });
            }
            else
            {
                string failMessage = model.Action == "Add" ? "系統申請失敗：" : "系統修改失敗：";
                return Json(new { success = false, message = failMessage + result });
            }
        }
        catch (Exception ex)
        {
            return Json(new { success = false, message = "系統處理發生錯誤：" + ex.Message });
        }
    }

    // 系統申請處理流程
    private string ProcessSystemApply(string sysId, string sysName, string empNo, string empName)
    {
        string result = null;

        // 1: 檢查系統是否存在於 AP_SYS
        bool systemExists = F_SYS.CheckSystemExistsInApSys(sysId);

        if (!systemExists)
        {
            // 系統不存在 -> 新增系統
            result = F_SYS.InsertSystemToApSys(sysId, sysName, empNo);
            if (result != null && result.Contains("fail")) return result;
        }
        else
        {
            // 系統存在 -> 更新系統名稱
            result = F_SYS.UpdateSystemName(sysId, sysName, empNo);
            if (result != null && result.Contains("fail")) return result;
        }

        // 2: 檢查是否有 001 群組
        bool group001Exists = F_SYS.CheckSystemHasGroup001(sysId);
        if (!group001Exists)
        {
            // 001 群組不存在 -> 新增 001 群組
            result = F_SYS.InsertGroup001(sysId, empNo);
            if (result != null && result.Contains("fail")) return result;
        }

        // 3: 檢查使用者是否已在 001 群組
        bool userExists = F_SYS.CheckUserInGroup001(sysId, empNo);
        if (!userExists)
        {
            // 使用者不存在 -> 新增使用者到 001 群組
            result = F_SYS.InsertUserToGroup001(sysId, empNo, empName);
            if (result != null && result.Contains("fail")) return result;
        }

        return result;
    }
    #endregion

//---factory
namespace HI_APACCESS.Factory.F_SYS
{
    public class F_SYS
    {
        SVS_DBmanager SVS_DBmanager = new SVS_DBmanager();

        // 取得登入員工可維護的系統清單(001群組)
        public List<M_SYS> GetAvailableSystems(string empNo)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.GetAvailableSystems);

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@EMP_NO", empNo)
            };

            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            return SVS_DBmanager.ConvertToList<M_SYS>(dt);
        }

        // 取得可維護系統選項(用於下拉選單)
        public List<M_SYS_Option> GetMaintainableSystemOptions(string empNo)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.GetMaintainableSystemOptions);

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@EMP_NO", empNo)
            };

            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            return SVS_DBmanager.ConvertToList<M_SYS_Option>(dt);
        }

        // 檢查系統是否存在於AP_SYS
        public bool CheckSystemExistsInApSys(string sysId)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.CheckSystemExistsInApSys);

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId)
            };

            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            return dt.Rows.Count > 0 && Convert.ToInt32(dt.Rows[0][0]) > 0;
        }

        // 檢查系統是否有001群組
        public bool CheckSystemHasGroup001(string sysId)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.CheckSystemHasGroup001);

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId)
            };

            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            return dt.Rows.Count > 0 && Convert.ToInt32(dt.Rows[0][0]) > 0;
        }

        // 取得員工姓名
        public string GetEmployeeName(string empNo)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.GetEmployeeName);

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@EMP_NO", empNo)
            };

            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            if (dt.Rows.Count > 0)
            {
                return dt.Rows[0]["EMP_NAME"].ToString();
            }
            return "";
        }

        // 新增系統到AP_SYS
        public string InsertSystemToApSys(string sysId, string sysName, string creator)
        {
            string sql = @"
                INSERT INTO [HI-APLOG].[dbo].[AP_SYS] 
                ([SYS_ID], [SYS_NAME], [CREATE_TIME], [CREATOR])
                VALUES (@SYS_ID, @SYS_NAME, GETDATE(), @CREATOR)";

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId),
                new SqlParameter("@SYS_NAME", sysName),
                new SqlParameter("@CREATOR", creator)
            };

            return SVS_DBmanager.ExecuteSQL(sql, parameters);
        }

        // 更新系統名稱
        public string UpdateSystemName(string sysId, string sysName, string editor)
        {
            string sql = @"
                UPDATE [HI-APLOG].[dbo].[AP_SYS] 
                SET [SYS_NAME] = @SYS_NAME, [EDIT_TIME] = GETDATE(), [EDITOR] = @EDITOR
                WHERE [SYS_ID] = @SYS_ID";

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId),
                new SqlParameter("@SYS_NAME", sysName),
                new SqlParameter("@EDITOR", editor)
            };

            return SVS_DBmanager.ExecuteSQL(sql, parameters);
        }

        // 新增001群組
        public string InsertGroup001(string sysId, string creator)
        {
            string sql = @"
                INSERT INTO [HI-AUTOS].[dbo].[AP_GROUP] 
                ([SYS_ID], [APG_NO], [APG_NAME], [CREATE_TIME], [CREATOR])
                VALUES (@SYS_ID, '001', N'管理員(資訊)', GETDATE(), @CREATOR)";

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId),
                new SqlParameter("@CREATOR", creator)
            };

            return SVS_DBmanager.ExecuteSQL(sql, parameters);
        }

        // 新增使用者到001群組
        public string InsertUserToGroup001(string sysId, string empNo, string empName)
        {
            string sql = @"
                INSERT INTO [HI-AUTOS].[dbo].[AP_USER] 
                ([SYS_ID], [APG_NO], [U_ID], [U_NAME], [CREATE_TIME], [CREATOR])
                VALUES (@SYS_ID, '001', @U_ID, @U_NAME, GETDATE(), @CREATOR)";

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId),
                new SqlParameter("@U_ID", empNo),
                new SqlParameter("@U_NAME", empName),
                new SqlParameter("@CREATOR", empNo)
            };

            return SVS_DBmanager.ExecuteSQL(sql, parameters);
        }

        // 檢查使用者是否已在001群組
        public bool CheckUserInGroup001(string sysId, string empNo)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.CheckUserInGroup001);

            List<SqlParameter> parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId),
                new SqlParameter("@U_ID", empNo)
            };

            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            return dt.Rows.Count > 0 && Convert.ToInt32(dt.Rows[0][0]) > 0;
        }
    }
}

