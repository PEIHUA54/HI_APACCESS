                    }, JsonRequestBehavior.AllowGet);
                }
            }
            catch (Exception ex)
            {
                return Json(new
                {
                    success = false,
                    message = $"查詢失敗: {ex.Message}"
                }, JsonRequestBehavior.AllowGet);
            }
        }

