    // 系統申請(新增/修改)
    [HttpPost]
    public JsonResult ApplySystem([Bind] M_SYS_Apply model)
    {
        try
        {
            if (!ModelState.IsValid)
                return Json(new { success = false, message = "資料驗證失敗" });

            string empNo   = this.Emp_NO;
            string empName = F_SYS.GetEmployeeName(empNo);

            if (string.IsNullOrEmpty(empName))
                return Json(new { success = false, message = "無法取得員工姓名" });

            bool systemExists  = F_SYS.CheckSystemExistsInApSys(model.SYS_ID);
            bool group001Exists = F_SYS.CheckSystemHasGroup001(model.SYS_ID);
            bool userExists    = F_SYS.CheckUserInGroup001(model.SYS_ID, empNo);

            if (model.Action == "Add" && systemExists && group001Exists && userExists)
            {
                return Json(new
                {
                    success = false,
                    message = "此系統已完成申請，您已具有管理權限。\r\n如需修改系統名稱，請點擊修改按鈕。"
                });
            }

            string result = ProcessSystemApply(model, empNo, empName);

            if (result == null || !result.Contains("fail"))
            {
                string successMessage = model.Action == "Add" ? "系統申請成功" : "系統修改成功";
                return Json(new { success = true, message = successMessage });
            }
            else
            {
                string failMessage = model.Action == "Add" ? "系統申請失敗：" : "系統修改失敗：";
                return Json(new { success = false, message = failMessage + result });
            }
        }
        catch (Exception ex)
        {
            return Json(new { success = false, message = "系統處理發生錯誤：" + ex.Message });
        }
    }

    // 系統申請處理流程
    private string ProcessSystemApply(M_SYS_Apply model, string empNo, string empName)
    {
        string result = null;

        bool systemExists = F_SYS.CheckSystemExistsInApSys(model.SYS_ID);

        if (!systemExists)
        {
            result = F_SYS.InsertSystemToApSys(model, empNo);
            if (result != null && result.Contains("fail")) return result;
        }
        else
        {
            result = F_SYS.UpdateSystem(model, empNo);
            if (result != null && result.Contains("fail")) return result;
        }

        bool group001Exists = F_SYS.CheckSystemHasGroup001(model.SYS_ID);
        if (!group001Exists)
        {
            result = F_SYS.InsertGroup001(model.SYS_ID, empNo);
            if (result != null && result.Contains("fail")) return result;
        }

        bool userExists = F_SYS.CheckUserInGroup001(model.SYS_ID, empNo);
        if (!userExists)
        {
            result = F_SYS.InsertUserToGroup001(model.SYS_ID, empNo, empName);
            if (result != null && result.Contains("fail")) return result;
        }

        return result;
    }

    // 取得員工清單
    [HttpGet]
    public JsonResult GetEmployeeList(string keyword = "")
    {
        try
        {
            // 搜尋前轉大寫（前端也會轉，這裡雙保險）
            string kw = string.IsNullOrWhiteSpace(keyword) ? "" : keyword.Trim().ToUpper();

            var employees = F_SYS.GetEmployeeList(kw);

            var result = employees.Select(emp => new {
                id   = emp.EMP_NO,
                text = emp.EMP_NO + " - " + emp.EMP_NAME
            });

            return Json(new { success = true, data = result }, JsonRequestBehavior.AllowGet);
        }
        catch (Exception ex)
        {
            return Json(new { success = false, message = "取得員工清單失敗：" + ex.Message }, JsonRequestBehavior.AllowGet);
        }
    }

    // 依員工編號清單補回姓名（編輯時使用）
    [HttpGet]
    public JsonResult GetEmployeesByNos(string empNos)
    {
        try
        {
            if (string.IsNullOrWhiteSpace(empNos))
                return Json(new { success = true, data = new List<object>() }, JsonRequestBehavior.AllowGet);

            var noList = empNos.Split(';')
                               .Select(s => s.Trim().ToUpper())
                               .Where(s => !string.IsNullOrEmpty(s))
                               .ToList();

            var allEmployees = F_SYS.GetEmployeeList("");

            var matched = allEmployees
                .Where(e => noList.Contains(e.EMP_NO.ToUpper()))
                .Select(e => new {
                    id   = e.EMP_NO,
                    text = e.EMP_NO + " - " + e.EMP_NAME
                })
                .ToList();

            return Json(new { success = true, data = matched }, JsonRequestBehavior.AllowGet);
        }
        catch (Exception ex)
        {
            return Json(new { success = false, message = "查詢失敗：" + ex.Message }, JsonRequestBehavior.AllowGet);
        }
    }

    // 取得Controller清單
    [HttpGet]
    public JsonResult GetControllerList(string sysId)
    {
        try
        {
            var controllers = F_SYS.GetControllerList(sysId);
            return Json(new { success = true, data = controllers }, JsonRequestBehavior.AllowGet);
        }
        catch (Exception ex)
        {
            return Json(new { success = false, message = "取得Controller清單失敗：" + ex.Message }, JsonRequestBehavior.AllowGet);
        }
    }

    // 取得系統詳細資料（編輯用）
    [HttpGet]
    public JsonResult GetSystemDetail(string sysId)
    {
        try
        {
            var systems = F_SYS.GetAvailableSystems(this.Emp_NO);
            var system  = systems.FirstOrDefault(s => s.SYS_ID == sysId);

            if (system != null)
                return Json(new { success = true, data = system }, JsonRequestBehavior.AllowGet);
            else
                return Json(new { success = false, message = "找不到系統資料" }, JsonRequestBehavior.AllowGet);
        }
        catch (Exception ex)
        {
            return Json(new { success = false, message = "取得系統資料失敗：" + ex.Message }, JsonRequestBehavior.AllowGet);
        }
    }

