DECLARE @SYS_ID VARCHAR(100) = 'HI_APACCESS'  -- 你的系統ID
DECLARE @CONTROLLER_NAME VARCHAR(100) = 'Account'  -- 剛才確認的值

-- 先看 AP_EVENT_LOG 裡有沒有這個 CONTROLLER_NAME 的資料
SELECT TOP 10 
    [ACTION_USER],
    [CONTROLLER_NAME],
    [ACTION_TIME]
FROM [HI-APLOG].[dbo].[AP_EVENT_LOG]
WHERE [SYS_ID] = @SYS_ID
  AND [CONTROLLER_NAME] = @CONTROLLER_NAME
ORDER BY [ACTION_TIME] DESC
