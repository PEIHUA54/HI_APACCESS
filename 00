根據你的需求，需要新增以下 Model：

using System;
using System.Collections.Generic;
using System.ComponentModel.DataAnnotations;
using System.Linq;
using System.Web;

namespace HI_APACCESS.Models.M_SYS
{
    // 系統清單
    public class M_SYS
    {
        [Display(Name = "系統ID")]
        public string SYS_ID { get; set; }

        [Display(Name = "系統名稱")]
        public string SYS_NAME { get; set; }

        [Display(Name = "建立人員")]
        public string CREATOR { get; set; }

        [Display(Name = "建立日期")]
        public string CREATE_TIME { get; set; }

        [Display(Name = "修改人員")]
        public string EDITOR { get; set; }

        [Display(Name = "修改日期")]
        public string EDIT_TIME { get; set; }

        [Display(Name = "權限通知對象_資訊人員")]
        public string NOTIFY_AUTOS_IT { get; set; }

        [Display(Name = "權限通知對象_一般USER")]
        public string NOTIFY_AUTOS_USERS { get; set; }

        [Display(Name = "權限CONTROLLER名稱")]
        public string AUTOS_CONTROLLER_NAME { get; set; }
    }

    // 系統申請/修改
    public class M_SYS_Apply
    {
        [Display(Name = "系統ID")]
        [Required(ErrorMessage = "系統ID為必填")]
        [StringLength(50, ErrorMessage = "系統ID長度不可超過50字元")]
        public string SYS_ID { get; set; }

        [Display(Name = "系統名稱")]
        [Required(ErrorMessage = "系統名稱為必填")]
        [StringLength(100, ErrorMessage = "系統名稱長度不可超過100字元")]
        public string SYS_NAME { get; set; }

        public string Action { get; set; } // "Add" or "Edit"

        [Display(Name = "權限通知對象_資訊人員")]
        public string NOTIFY_AUTOS_IT { get; set; }

        [Display(Name = "權限通知對象_一般USER")]
        public string NOTIFY_AUTOS_USERS { get; set; }

        [Display(Name = "權限CONTROLLER名稱")]
        public string AUTOS_CONTROLLER_NAME { get; set; }
    }

    // 可維護系統下拉選項
    public class M_SYS_Option
    {
        [Display(Name = "系統ID")]
        public string SYS_ID { get; set; }

        [Display(Name = "系統名稱")]
        public string SYS_NAME { get; set; }

        public string DisplayText => $"{SYS_ID} - {SYS_NAME}";
    }

    // 系統申請結果
    public class M_SYS_ApplyResult
    {
        public bool Success { get; set; }
        public string Message { get; set; }
        public int Scenario { get; set; } // 1, 2, or 3 (對應三種新增情況)
    }

    // 新增：員工選項Model（用於下拉選單）
    public class EmployeeOption
    {
        [Display(Name = "員工編號")]
        public string EMP_NO { get; set; }

        [Display(Name = "員工姓名")]
        public string EMP_NAME { get; set; }

        public string DisplayText => $"{EMP_NO} - {EMP_NAME}";
    }

    // 新增：Controller選項Model（用於下拉選單）
    public class ControllerOption
    {
        [Display(Name = "Controller名稱")]
        public string CONTROLLER_NAME { get; set; }
    }

    //REQUEST
    public class GetUrlRequsetModel
    {
        public string SysID { get; set; }
        public string Type { get; set; }
        public string Environment { get; set; }
    }

    //RESPONSE
    public class GetUrlResponseModel
    {
        public string Result_code { get; set; }
        public string Msg { get; set; }
        public string Url { get; set; }
    }
}


新增的 Model：
	1.	EmployeeOption - 用於資訊人員和一般USER的下拉選單
	∙	EMP_NO：員工編號
	∙	EMP_NAME：員工姓名
	∙	DisplayText：組合顯示文字（員工編號 - 員工姓名）
	2.	ControllerOption - 用於Controller的下拉選單
	∙	CONTROLLER_NAME：Controller名稱
這兩個 Model 會在 AJAX 調用 GetEmployeeList 和 GetControllerList 時使用，方便 Select2 下拉選單顯示和選擇。​​​​​​​​​​​​​​​​