// 取得員工清單
public List<EmployeeOption> GetEmployeeList(string keyword = "")
{
    string sql = @"
    SELECT [EMP_NO], [EMP_NAME]
    FROM [HI-AUTOS].[dbo].[M1EMP_MAST]
    WHERE 1=1";

    List<SqlParameter> parameters = new List<SqlParameter>();

    if (!string.IsNullOrWhiteSpace(keyword))
    {
        sql += " AND ([EMP_NO] LIKE @KEYWORD OR [EMP_NAME] LIKE @KEYWORD)";
        parameters.Add(new SqlParameter("@KEYWORD", $"%{keyword}%"));
    }

    sql += " ORDER BY [EMP_NO]";

    DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
    return SVS_DBmanager.ConvertToList<EmployeeOption>(dt);
}

// 取得Controller清單
public List<ControllerOption> GetControllerList(string sysId)
{
    string sql = @"
    SELECT DISTINCT [CONTROLLER_NAME]
    FROM [HI-APLOG].[dbo].[AP_SYS_CTRL]
    WHERE [SYS_ID] = @SYS_ID
    ORDER BY [CONTROLLER_NAME]";

    List<SqlParameter> parameters = new List<SqlParameter>
    {
        new SqlParameter("@SYS_ID", sysId)
    };

    DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
    return SVS_DBmanager.ConvertToList<ControllerOption>(dt);
}


