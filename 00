// 取得員工清單
public List<EmployeeOption> GetEmployeeList(string keyword = "")
{
    string sql = @"
    SELECT [EMP_NO], [EMP_NAME]
    FROM [HI-AUTOS].[dbo].[M1EMP_MAST]
    WHERE 1=1";

    List<SqlParameter> parameters = new List<SqlParameter>();

    if (!string.IsNullOrWhiteSpace(keyword))
    {
        sql += " AND ([EMP_NO] LIKE @KEYWORD OR [EMP_NAME] LIKE @KEYWORD)";
        parameters.Add(new SqlParameter("@KEYWORD", $"%{keyword}%"));
    }

    sql += " ORDER BY [EMP_NO]";

    DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
    return SVS_DBmanager.ConvertToList<EmployeeOption>(dt);
}

// 取得Controller清單
public List<ControllerOption> GetControllerList(string sysId)
{
    string sql = @"
    SELECT DISTINCT [CONTROLLER_NAME]
    FROM [HI-APLOG].[dbo].[AP_SYS_CTRL]
    WHERE [SYS_ID] = @SYS_ID
    ORDER BY [CONTROLLER_NAME]";

    List<SqlParameter> parameters = new List<SqlParameter>
    {
        new SqlParameter("@SYS_ID", sysId)
    };

    DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
    return SVS_DBmanager.ConvertToList<ControllerOption>(dt);
}

// 新增系統到AP_SYS（包含新欄位）
public string InsertSystemToApSys(M_SYS_Apply model, string creator)
{
    string sql = @"
    INSERT INTO [HI-APLOG].[dbo].[AP_SYS] 
    ([SYS_ID], [SYS_NAME], [NOTIFY_AUTOS_IT], [NOTIFY_AUTOS_USERS], [AUTOS_CONTROLLER_NAME], [CREATE_TIME], [CREATOR])
    VALUES (@SYS_ID, @SYS_NAME, @NOTIFY_AUTOS_IT, @NOTIFY_AUTOS_USERS, @AUTOS_CONTROLLER_NAME, GETDATE(), @CREATOR)";

    List<SqlParameter> parameters = new List<SqlParameter>
    {
        new SqlParameter("@SYS_ID", model.SYS_ID),
        new SqlParameter("@SYS_NAME", model.SYS_NAME),
        new SqlParameter("@NOTIFY_AUTOS_IT", model.NOTIFY_AUTOS_IT ?? (object)DBNull.Value),
        new SqlParameter("@NOTIFY_AUTOS_USERS", model.NOTIFY_AUTOS_USERS ?? (object)DBNull.Value),
        new SqlParameter("@AUTOS_CONTROLLER_NAME", model.AUTOS_CONTROLLER_NAME ?? (object)DBNull.Value),
        new SqlParameter("@CREATOR", creator)
    };

    return SVS_DBmanager.ExecuteSQL(sql, parameters);
}

// 更新系統（包含新欄位）
public string UpdateSystem(M_SYS_Apply model, string editor)
{
    string sql = @"
    UPDATE [HI-APLOG].[dbo].[AP_SYS] 
    SET [SYS_NAME] = @SYS_NAME, 
        [NOTIFY_AUTOS_IT] = @NOTIFY_AUTOS_IT, 
        [NOTIFY_AUTOS_USERS] = @NOTIFY_AUTOS_USERS, 
        [AUTOS_CONTROLLER_NAME] = @AUTOS_CONTROLLER_NAME,
        [EDIT_TIME] = GETDATE(), 
        [EDITOR] = @EDITOR
    WHERE [SYS_ID] = @SYS_ID";

    List<SqlParameter> parameters = new List<SqlParameter>
    {
        new SqlParameter("@SYS_ID", model.SYS_ID),
        new SqlParameter("@SYS_NAME", model.SYS_NAME),
        new SqlParameter("@NOTIFY_AUTOS_IT", model.NOTIFY_AUTOS_IT ?? (object)DBNull.Value),
        new SqlParameter("@NOTIFY_AUTOS_USERS", model.NOTIFY_AUTOS_USERS ?? (object)DBNull.Value),
        new SqlParameter("@AUTOS_CONTROLLER_NAME", model.AUTOS_CONTROLLER_NAME ?? (object)DBNull.Value),
        new SqlParameter("@EDITOR", editor)
    };

    return SVS_DBmanager.ExecuteSQL(sql, parameters);
}


