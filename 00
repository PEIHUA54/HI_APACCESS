using HI_APACCESS.Models.M_AUTOS;
using HI_APACCESS.Service;
using System;
using System.Collections.Generic;
using System.Data;
using System.Data.SqlClient;
using System.Linq;

namespace HI_APACCESS.Factory.F_AUTOS
{
    public class F_AUTOS
    {
        SVS_DBmanager SVS_DBmanager = new SVS_DBmanager();

        // 取得所有系統
        public List<M_AUTOS_SYS> GetAllSystemsForBatch()
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.GetAllSystemsForBatch);
            DataTable dt = SVS_DBmanager.QueryBySQL(sql, new List<SqlParameter>());
            return SVS_DBmanager.ConvertToList<M_AUTOS_SYS>(dt);
        }

        // 帳號清單
        public List<M_AUTOS_UserExport> GetUserListForMail(string sysId, string sysName)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.GetUserListForMail);
            var parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId)
            };
            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            var list = SVS_DBmanager.ConvertToList<M_AUTOS_UserExport>(dt);
            list.ForEach(x => x.SYS_NAME = sysName);
            return list;
        }

        // 登入次數清單
        public List<M_AUTOS_LoginCount> GetLoginCountList(string sysId, string sysName)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.GetLoginCountList);
            var parameters = new List<SqlParameter>
            {
                new SqlParameter("@SYS_ID", sysId)
            };
            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            var list = SVS_DBmanager.ConvertToList<M_AUTOS_LoginCount>(dt);
            list.ForEach(x => x.SYS_NAME = sysName);
            return list;
        }

        // 取得單一員工信箱
        public string GetEmpEmail(string empNo)
        {
            string sql = SVS_DBmanager.GetQuery(SVS_DBmanager.QueryKey.GetEmpEmail);
            var parameters = new List<SqlParameter>
            {
                new SqlParameter("@EMP_NO", empNo)
            };
            DataTable dt = SVS_DBmanager.QueryBySQL(sql, parameters);
            if (dt.Rows.Count > 0)
                return dt.Rows[0]["EMP_EMAIL"]?.ToString();
            return null;
        }

        // 批次取得信箱清單（; 分隔的員工編號字串）
        public List<string> GetEmpEmailList(string empNosStr)
        {
            if (string.IsNullOrWhiteSpace(empNosStr))
                return new List<string>();

            return empNosStr.Split(';')
                            .Select(s => s.Trim())
                            .Where(s => !string.IsNullOrEmpty(s))
                            .Select(empNo => GetEmpEmail(empNo))
                            .Where(email => !string.IsNullOrEmpty(email))
                            .ToList();
        }
    }
}


