@section Scripts{
    <!-- 加入 Select2 -->
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

    <script>
        $(document).ready(function () {
            initPage();
        });

        function initPage() {
            // 新增按鈕事件
            $('#btnAdd').off('click').on('click', function () {
                resetForm();
                $('#modalTitle').text('新增系統');
                $('#sysId').prop('readonly', false);
                $('#actionType').val('Add');
                initSelect2();
                $('#systemModal').modal('show');
            });

            // 修改按鈕事件
            $('.btn-edit').off('click').on('click', function () {
                var sysId = $(this).data('sysid');
                var sysName = $(this).data('sysname');
                editSystem(sysId, sysName);
            });

            // 儲存按鈕事件
            $('#btnSave').off('click').on('click', function () {
                saveSystem();
            });

            // 監聽系統ID輸入，載入對應的Controller清單
            $('#sysId').on('blur', function () {
                var sysId = $(this).val().trim();
                if (sysId) {
                    loadControllerList(sysId);
                }
            });
        }

        // 自訂 Select2 的顯示模板（表格形式）
        function formatEmployee(employee) {
            if (!employee.id) {
                return employee.text;
            }

            var parts = employee.text.split(' - ');
            var empNo = parts[0] || '';
            var empName = parts[1] || '';

            var $employee = $(
                '<table class="employee-option-table">' +
                    '<tr>' +
                        '<td style="width: 40%; text-align: left;">' + empNo + '</td>' +
                        '<td style="width: 60%; text-align: left;">' + empName + '</td>' +
                    '</tr>' +
                '</table>'
            );

            return $employee;
        }

        // 初始化 Select2
        function initSelect2() {
            // 資訊人員選擇
            $('#notifyIt').select2({
                ajax: {
                    url: '@Url.Action("GetEmployeeList", "SYS")',
                    dataType: 'json',
                    delay: 300,
                    data: function (params) {
                        return {
                            keyword: params.term || ''
                        };
                    },
                    processResults: function (data) {
                        if (data.success) {
                            return {
                                results: data.data
                            };
                        }
                        return { results: [] };
                    }
                },
                templateResult: formatEmployee,
                templateSelection: function (employee) {
                    return employee.text || employee.id;
                },
                placeholder: '請輸入員工編號或姓名搜尋',
                allowClear: true,
                minimumInputLength: 0,
                width: '100%'
            });

            // 一般USER選擇
            $('#notifyUsers').select2({
                ajax: {
                    url: '@Url.Action("GetEmployeeList", "SYS")',
                    dataType: 'json',
                    delay: 300,
                    data: function (params) {
                        return {
                            keyword: params.term || ''
                        };
                    },
                    processResults: function (data) {
                        if (data.success) {
                            return {
                                results: data.data
                            };
                        }
                        return { results: [] };
                    }
                },
                templateResult: formatEmployee,
                templateSelection: function (employee) {
                    return employee.text || employee.id;
                },
                placeholder: '請輸入員工編號或姓名搜尋',
                allowClear: true,
                minimumInputLength: 0,
                width: '100%'
            });

            // 監聽資訊人員選擇變化
            $('#notifyIt').on('change', function () {
                updateSelectedDisplay('It');
            });

            // 監聽一般USER選擇變化
            $('#notifyUsers').on('change', function () {
                updateSelectedDisplay('Users');
            });

            // 監聽Controller選擇變化
            $('#controllerName').on('change', function () {
                updateControllerDisplay();
            });
        }

        // 更新已選擇人員的顯示
        function updateSelectedDisplay(type) {
            var selectId = type === 'It' ? '#notifyIt' : '#notifyUsers';
            var listId = type === 'It' ? '#selectedItList' : '#selectedUsersList';
            var contentId = type === 'It' ? '#selectedItContent' : '#selectedUsersContent';

            var selectedData = $(selectId).select2('data');

            if (selectedData.length > 0) {
                var html = '';
                selectedData.forEach(function (item) {
                    html += `<span class="selected-tag">${item.text}</span>`;
                });
                $(contentId).html(html);
                $(listId).show();
            } else {
                $(listId).hide();
            }
        }

        // 更新已選擇Controller的顯示
        function updateControllerDisplay() {
            var selectedValue = $('#controllerName').val();
            var selectedText = $('#controllerName option:selected').text();

            if (selectedValue) {
                $('#selectedControllerContent').html(`<span class="selected-tag">${selectedText}</span>`);
                $('#selectedController').show();
            } else {
                $('#selectedController').hide();
            }
        }

        // 載入Controller清單
        function loadControllerList(sysId) {
            $.get('@Url.Action("GetControllerList", "SYS")', { sysId: sysId }, function (response) {
                var options = '<option value="">-- 請選擇Controller --</option>';
                if (response.success && response.data) {
                    response.data.forEach(function (ctrl) {
                        options += `<option value="${ctrl.CONTROLLER_NAME}">${ctrl.CONTROLLER_NAME}</option>`;
                    });
                }
                $('#controllerName').html(options);
            });
        }

        // 儲存系統
        function saveSystem() {
            var notifyIt = $('#notifyIt').val();
            var notifyUsers = $('#notifyUsers').val();

            var formData = {
                SYS_ID: $('#sysId').val().trim(),
                SYS_NAME: $('#sysName').val().trim(),
                NOTIFY_AUTOS_IT: notifyIt ? notifyIt.join(',') : '',
                NOTIFY_AUTOS_USERS: notifyUsers ? notifyUsers.join(',') : '',
                AUTOS_CONTROLLER_NAME: $('#controllerName').val() || '',
                Action: $('#actionType').val()
            };

            if (!formData.SYS_ID || !formData.SYS_NAME) {
                alert('系統ID和系統名稱為必填');
                return;
            }

            $.ajax({
                url: '@Url.Action("ApplySystem", "SYS")',
                type: 'POST',
                data: formData,
                dataType: 'json',
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        $('#systemModal').modal('hide');
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert('儲存時發生錯誤');
                }
            });
        }

        // 編輯系統
        function editSystem(sysId, sysName) {
            resetForm();
            $('#modalTitle').text('修改系統');
            $('#sysId').val(sysId).prop('readonly', true);
            $('#sysName').val(sysName);
            $('#actionType').val('Edit');

            initSelect2();
            loadControllerList(sysId);

            // 載入現有的資料
            $.get('@Url.Action("GetSystemDetail", "SYS")', { sysId: sysId }, function (response) {
                if (response.success) {
                    var system = response.data;

                    // 設定資訊人員
                    if (system.NOTIFY_AUTOS_IT) {
                        var itList = system.NOTIFY_AUTOS_IT.split(',');
                        itList.forEach(function (empNo) {
                            if (empNo.trim()) {
                                var option = new Option(empNo, empNo, true, true);
                                $('#notifyIt').append(option);
                            }
                        });
                        $('#notifyIt').trigger('change');
                    }

                    // 設定一般USER
                    if (system.NOTIFY_AUTOS_USERS) {
                        var usersList = system.NOTIFY_AUTOS_USERS.split(',');
                        usersList.forEach(function (empNo) {
                            if (empNo.trim()) {
                                var option = new Option(empNo, empNo, true, true);
                                $('#notifyUsers').append(option);
                            }
                        });
                        $('#notifyUsers').trigger('change');
                    }

                    // 設定Controller
                    if (system.AUTOS_CONTROLLER_NAME) {
                        setTimeout(function () {
                            $('#controllerName').val(system.AUTOS_CONTROLLER_NAME);
                            updateControllerDisplay();
                        }, 500);
                    }
                }
            });

            $('#systemModal').modal('show');
        }

        // 重置表單
        function resetForm() {
            $('#systemForm')[0].reset();
            $('#sysId').prop('readonly', false);
            $('#selectedItList, #selectedUsersList, #selectedController').hide();

            // 清除 Select2
            if ($('#notifyIt').hasClass('select2-hidden-accessible')) {
                $('#notifyIt').select2('destroy');
            }
            if ($('#notifyUsers').hasClass('select2-hidden-accessible')) {
                $('#notifyUsers').select2('destroy');
            }
        }
    </script>
}


