// 修改：系統申請處理流程
private string ProcessSystemApply(M_SYS_Apply model, string empNo, string empName)
{
    string result = null;

    // 1: 檢查系統是否存在於 AP_SYS
    bool systemExists = F_SYS.CheckSystemExistsInApSys(model.SYS_ID);

    if (!systemExists)
    {
        // 系統不存在 -> 新增系統（包含新欄位）
        result = F_SYS.InsertSystemToApSys(model, empNo);
        if (result != null && result.Contains("fail")) return result;
    }
    else
    {
        // 系統存在 -> 更新系統（包含新欄位）
        result = F_SYS.UpdateSystem(model, empNo);
        if (result != null && result.Contains("fail")) return result;
    }

    // 2: 檢查是否有 001 群組
    bool group001Exists = F_SYS.CheckSystemHasGroup001(model.SYS_ID);
    if (!group001Exists)
    {
        // 001 群組不存在 -> 新增 001 群組
        result = F_SYS.InsertGroup001(model.SYS_ID, empNo);
        if (result != null && result.Contains("fail")) return result;
    }

    // 3: 檢查使用者是否已在 001 群組
    bool userExists = F_SYS.CheckUserInGroup001(model.SYS_ID, empNo);
    if (!userExists)
    {
        // 使用者不存在 -> 新增使用者到 001 群組
        result = F_SYS.InsertUserToGroup001(model.SYS_ID, empNo, empName);
        if (result != null && result.Contains("fail")) return result;
    }

    return result;
}


