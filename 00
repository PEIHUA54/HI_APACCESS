// 修改：取得員工清單 - 使用 HI_APACCESS_DLL
public List<EmployeeOption> GetEmployeeList(string keyword = "")
{
    try
    {
        // 準備請求參數
        var request = new
        {
            Type = "2",  // 2 = 在職人員
            EmpNoList = (List<string>)null,  // 不指定名單
            Environment = EnvHelper.EnvironmentForDll()
        };

        string requestJson = JsonConvert.SerializeObject(request);
        
        // 呼叫 DLL 取得員工資料
        string responseJson = new HI_APACCESS_DLL.APACCESS().GetEmpMast(requestJson);
        
        // 解析回應
        var response = JsonConvert.DeserializeObject<GetEmpMastResponse>(responseJson);
        
        // 注意：DLL 回傳的是 Result 不是 EmpList
        if (response.Result_code == "0000" && response.Result != null && response.Result.Count > 0)
        {
            var employees = response.Result.Select(emp => new EmployeeOption
            {
                EMP_NO = emp.EmpNo,      // DLL 欄位是 EmpNo
                EMP_NAME = emp.EmpName   // DLL 欄位是 EmpName
            }).ToList();

            // 如果有關鍵字，進行過濾
            if (!string.IsNullOrWhiteSpace(keyword))
            {
                employees = employees.Where(e => 
                    e.EMP_NO.Contains(keyword) || 
                    e.EMP_NAME.Contains(keyword)
                ).ToList();
            }

            return employees;
        }
        else
        {
            return new List<EmployeeOption>();
        }
    }
    catch (Exception ex)
    {
        return new List<EmployeeOption>();
    }
}


Controller、View 都不需要改
其他的 Controller 和 View 程式碼保持不變，就是之前給你的完整版本。

總結
需要修改的地方：
	1.	✅ Model - 修改兩個類別（GetEmpMastResponse 和 EmpMastData）
	2.	✅ Factory - 修改 GetEmployeeList 方法
	3.	❌ Controller - 不需要改
	4.	❌ View - 不需要改
Controller 下拉選單邏輯：
	∙	新系統申請時：沒有 Controller 可選（下拉選單空白）
	∙	編輯現有系統時：可以從下拉選單選擇該系統已有的 Controller
	∙	要新增 Controller：需要先在 AP_SYS_CTRL 資料表中新增記錄後，才能在系統申請中選擇​​​​​​​​​​​​​​​​