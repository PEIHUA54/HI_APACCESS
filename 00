using HI_APACCESS.Factory.F_AUTOS;
using HI_APACCESS.Models.M_AUTOS;
using OfficeOpenXml;
using OfficeOpenXml.Style;
using System;
using System.Collections.Generic;
using System.Drawing;
using System.IO;
using System.Net.Mail;
using System.Web.Mvc;

namespace HI_APACCESS.Controllers
{
    public class AUTOSController : HI_APACCESSBaseController
    {
        private readonly F_AUTOS F_AUTOS = new F_AUTOS();

        // TODO: 確認寄件者信箱後替換
        private const string MAIL_SENDER      = "hi_apaccess@EXC1.hilife.com";
        private const string MAIL_SENDER_NAME = "帳號盤點通知系統";
        private const string SMTP_HOST        = "10.8.254.33";
        private const int    SMTP_PORT        = 25;

        #region 頁面（空白）

        public ActionResult BatchAutos()
        {
            return View();
        }

        #endregion

        #region 批次寄信（工作排程呼叫）

        [HttpGet]
        public ActionResult AutosBatch()
        {
            var resultList = new List<M_AUTOS_BatchResult>();

            try
            {
                var systems = F_AUTOS.GetAllSystemsForBatch();

                foreach (var sys in systems)
                {
                    var result = new M_AUTOS_BatchResult
                    {
                        SYS_ID   = sys.SYS_ID,
                        SYS_NAME = sys.SYS_NAME
                    };

                    try
                    {
                        // 沒設定收件者 → 略過
                        if (string.IsNullOrWhiteSpace(sys.NOTIFY_AUTOS_USERS))
                        {
                            result.Success = false;
                            result.Message = "未設定通知對象，略過";
                            resultList.Add(result);
                            continue;
                        }

                        // 取得收件者信箱
                        var toEmails = F_AUTOS.GetEmpEmailList(sys.NOTIFY_AUTOS_USERS);
                        var ccEmails = F_AUTOS.GetEmpEmailList(sys.NOTIFY_AUTOS_IT);

                        if (toEmails.Count == 0)
                        {
                            result.Success = false;
                            result.Message = "收件者查無信箱，略過";
                            resultList.Add(result);
                            continue;
                        }

                        // 產生 Excel
                        string ts         = DateTime.Now.ToString("yyyyMMddHHmmss");
                        string userFile   = $"{ts}_帳號清單";
                        string loginFile  = $"{ts}_登入使用次數清單";
                        var userList      = F_AUTOS.GetUserListForMail(sys.SYS_ID, sys.SYS_NAME);
                        var loginList     = F_AUTOS.GetLoginCountList(sys.SYS_ID, sys.SYS_NAME);
                        byte[] userExcel  = CreateUserExcel(userList,  sys.SYS_NAME);
                        byte[] loginExcel = CreateLoginExcel(loginList, sys.SYS_NAME);

                        // 寄信
                        SendInventoryMail(
                            sysName:       sys.SYS_NAME,
                            toEmails:      toEmails,
                            ccEmails:      ccEmails,
                            userExcel:     userExcel,
                            userFileName:  userFile,
                            loginExcel:    loginExcel,
                            loginFileName: loginFile
                        );

                        result.Success = true;
                        result.Message = $"寄信成功，收件者 {toEmails.Count} 人，CC {ccEmails.Count} 人";
                    }
                    catch (Exception ex)
                    {
                        result.Success = false;
                        result.Message = "失敗：" + ex.Message;
                    }

                    resultList.Add(result);
                }
            }
            catch (Exception ex)
            {
                return Json(new { success = false, message = "批次執行錯誤：" + ex.Message },
                            JsonRequestBehavior.AllowGet);
            }

            return Json(new { success = true, data = resultList },
                        JsonRequestBehavior.AllowGet);
        }

        #endregion

        #region 寄信

        private void SendInventoryMail(
            string sysName,
            List<string> toEmails,
            List<string> ccEmails,
            byte[] userExcel,  string userFileName,
            byte[] loginExcel, string loginFileName)
        {
            using (var mail = new MailMessage())
            {
                mail.From       = new MailAddress(MAIL_SENDER, MAIL_SENDER_NAME);
                mail.IsBodyHtml = true;
                mail.Priority   = MailPriority.Normal;

                // 收件者（正本）
                foreach (var email in toEmails)
                    mail.To.Add(new MailAddress(email));

                // CC（副本）
                foreach (var email in ccEmails)
                    mail.CC.Add(new MailAddress(email));

                // 主旨
                string period  = GetHalfYearPeriod();
                mail.Subject   = $"【帳號盤點通知】{sysName} - {period}";

                // 內文
                mail.Body = BuildMailBody(sysName, period);

                // 附件：帳號清單
                var s1 = new MemoryStream(userExcel);
                mail.Attachments.Add(new Attachment(s1,
                    userFileName + ".xlsx",
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"));

                // 附件：登入使用次數清單
                var s2 = new MemoryStream(loginExcel);
                mail.Attachments.Add(new Attachment(s2,
                    loginFileName + ".xlsx",
                    "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"));

                using (var smtp = new SmtpClient(SMTP_HOST))
                {
                    smtp.Port      = SMTP_PORT;
                    smtp.EnableSsl = false;
                    smtp.Send(mail);
                }
            }
        }

        private string BuildMailBody(string sysName, string period)
        {
            var b = "<html><body style='font-family:微軟正黑體; font-size:14px; line-height:2;'>";
            b += "<p>敬啟者，</p>";
            b += "<p>本信為系統自動發送之帳號盤點通知，請惠予查閱。</p>";
            b += "<br>";
            b += $"<p>系統名稱：<strong>{sysName}</strong></p>";
            b += $"<p>盤點期間：<strong>{period}</strong></p>";
            b += "<br>";
            b += "<p>隨信附上下列兩份清單，請確認清單內人員是否仍有系統使用需求：</p>";
            b += "<ol>";
            b += "  <li>帳號清單（系統名稱、帳號、姓名、群組、部門等）</li>";
            b += "  <li>登入使用次數清單（系統名稱、帳號、姓名、近半年登入次數）</li>";
            b += "</ol>";
            b += "<p>若有人員已離職或不再需要系統使用權限，<strong>請通知資訊人員進行帳號移除作業</strong>，以確保系統資安安全。</p>";
            b += "<br>";
            b += "<p>如有任何疑問，請洽資訊人員。</p>";
            b += "<br>";
            b += "<p style='color:#888; font-size:12px;'>※ 本信為系統自動發送，請勿直接回覆。</p>";
            b += "</body></html>";
            return b;
        }

        private string GetHalfYearPeriod()
        {
            var now = DateTime.Now;
            return now.Month <= 6
                ? $"{now.Year}年上半年（1月～6月）"
                : $"{now.Year}年下半年（7月～12月）";
        }

        #endregion

        #region 產生 Excel（不加密）

        private byte[] CreateUserExcel(List<M_AUTOS_UserExport> list, string sysName)
        {
            ExcelPackage.LicenseContext = LicenseContext.NonCommercial;
            using (var package = new ExcelPackage())
            {
                var ws      = package.Workbook.Worksheets.Add("帳號清單");
                var headers = new[] { "系統名稱", "帳號", "姓名", "群組代號", "群組名稱",
                                      "部門代號", "部門名稱", "建立人員", "建立日期",
                                      "修改人員", "修改日期" };
                SetHeaders(ws, headers);

                int row = 2;
                foreach (var item in list)
                {
                    ws.Cells[row, 1].Value  = sysName;
                    ws.Cells[row, 2].Value  = item.U_ID;
                    ws.Cells[row, 3].Value  = item.U_NAME;
                    ws.Cells[row, 4].Value  = item.APG_NO;
                    ws.Cells[row, 5].Value  = item.APG_NAME;
                    ws.Cells[row, 6].Value  = item.ORGAN_NO;
                    ws.Cells[row, 7].Value  = item.ORGAN_CAP;
                    ws.Cells[row, 8].Value  = item.CREATOR;
                    ws.Cells[row, 9].Value  = item.CREATE_TIME;
                    ws.Cells[row, 10].Value = item.EDITOR;
                    ws.Cells[row, 11].Value = item.EDIT_TIME;
                    SetDataRowStyle(ws, row, headers.Length);
                    row++;
                }

                AutoFitColumns(ws, headers.Length);
                ws.View.FreezePanes(2, 1);
                return package.GetAsByteArray();
            }
        }

        private byte[] CreateLoginExcel(List<M_AUTOS_LoginCount> list, string sysName)
        {
            ExcelPackage.LicenseContext = LicenseContext.NonCommercial;
            using (var package = new ExcelPackage())
            {
                var ws      = package.Workbook.Worksheets.Add("登入使用次數");
                var headers = new[] { "系統名稱", "帳號", "姓名", "登入次數" };
                SetHeaders(ws, headers);

                int row = 2;
                foreach (var item in list)
                {
                    ws.Cells[row, 1].Value = sysName;
                    ws.Cells[row, 2].Value = item.U_ID;
                    ws.Cells[row, 3].Value = item.U_NAME;
                    ws.Cells[row, 4].Value = item.LOGIN_COUNT;
                    SetDataRowStyle(ws, row, headers.Length);
                    row++;
                }

                AutoFitColumns(ws, headers.Length);
                ws.View.FreezePanes(2, 1);
                return package.GetAsByteArray();
            }
        }

        private void SetHeaders(ExcelWorksheet ws, string[] headers)
        {
            for (int i = 0; i < headers.Length; i++)
                ws.Cells[1, i + 1].Value = headers[i];

            using (var range = ws.Cells[1, 1, 1, headers.Length])
            {
                range.Style.Font.Bold      = true;
                range.Style.Font.Size      = 11;
                range.Style.Font.Name      = "微軟正黑體";
                range.Style.Fill.PatternType = ExcelFillStyle.Solid;
                range.Style.Fill.BackgroundColor.SetColor(Color.LightGray);
                range.Style.HorizontalAlignment = ExcelHorizontalAlignment.Center;
                range.Style.VerticalAlignment   = ExcelVerticalAlignment.Center;
                SetBorder(range);
            }
        }

        private void SetDataRowStyle(ExcelWorksheet ws, int row, int colCount)
        {
            using (var range = ws.Cells[row, 1, row, colCount])
            {
                range.Style.Font.Name         = "微軟正黑體";
                range.Style.VerticalAlignment = ExcelVerticalAlignment.Center;
                SetBorder(range);
            }
        }

        private void SetBorder(ExcelRange range)
        {
            range.Style.Border.Top.Style    = ExcelBorderStyle.Thin;
            range.Style.Border.Bottom.Style = ExcelBorderStyle.Thin;
            range.Style.Border.Left.Style   = ExcelBorderStyle.Thin;
            range.Style.Border.Right.Style  = ExcelBorderStyle.Thin;
        }

        private void AutoFitColumns(ExcelWorksheet ws, int colCount)
        {
            if (ws.Dimension == null) return;
            ws.Cells[ws.Dimension.Address].AutoFitColumns();
            for (int i = 1; i <= colCount; i++)
                ws.Column(i).Width += 2;
        }

        #endregion
    }
}


