改成這樣，加上 checkbox 但 disabled：

} else {
    // 非001：唯讀顯示，有checkbox但disabled不可操作
    buttonHtml += `
        <div class="btn-item ${hasPermission ? 'has-permission' : ''}" style="pointer-events:none;">
            <div class="permission-content">
                <input type="checkbox" class="permission-checkbox" ${hasPermission ? 'checked' : ''} disabled>
